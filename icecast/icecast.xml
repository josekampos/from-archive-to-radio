<icecast>
  <location>Portugal</location>
  <admin>you@example.com</admin>

  <limits>
    <clients>50</clients>
    <sources>2</sources>
    <threadpool>5</threadpool>
    <queue-size>524288</queue-size>
    <client-timeout>30</client-timeout>
    <header-timeout>15</header-timeout>
    <source-timeout>10</source-timeout>
    <burst-on-connect>1</burst-on-connect>
    <burst-size>65535</burst-size>
  </limits>

  <authentication>
   <source-password>CHANGE_ME_SOURCE</source-password>

   <relay-user>relay</relay-user>
   <relay-password>CHANGE_ME_RELAY</relay-password>

   <admin-user>admin</admin-user>
   <admin-password>CHANGE_ME_ADMIN123</admin-password>
  </authentication>

  <hostname>destarradio-1</hostname>

  <listen-socket>
    <port>8000</port>
  </listen-socket>

  <fileserve>0</fileserve>

  <mount>
    <mount-name>/live.aac</mount-name>
    <max-listeners>20</max-listeners>
    <public>0</public>
  </mount>

  <mount>
    <mount-name>/live.mp3</mount-name>
    <max-listeners>20</max-listeners>
    <public>0</public>
  </mount>

  <paths>
    <logdir>/var/log/icecast2</logdir>
    <webroot>/usr/share/icecast2/web</webroot>
    <adminroot>/usr/share/icecast2/admin</adminroot>
    <alias source="/" dest="/status.xsl"/>
  </paths>

  <logging>
    <accesslog>access.log</accesslog>
    <errorlog>error.log</errorlog>
    <loglevel>3</loglevel>
    <logsize>10000</logsize>
  </logging>

  <security>
    <chroot>0</chroot>
  </security>
</icecast>

